# ══════════════════════════════════════════════════════════════════════════════
# Quillan Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# This file controls how Quillan behaves. Every line that starts with a #
# is a comment — it is ignored by the program. Lines without a # are settings.
#
# TO USE THIS FILE:
#   Place this file in your working directory — Quillan will load it
#   automatically whenever you run a command from that directory.
#   You can also pass it explicitly: quillan --config quillan.env create my_story.txt
#
# Most settings already have sensible defaults. The only ones you *must*
# fill in are your API keys in the section below.
#
# ──────────────────────────────────────────────────────────────────────────────
# SECURITY NOTE: This file will contain your private API keys once you fill
# them in. Do not share it, email it, or upload it anywhere.
# ══════════════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 1 — API KEYS  (fill these in to get started)
# ──────────────────────────────────────────────────────────────────────────────
#
# Quillan uses three AI services. You will need an account and an API key
# from each one. An API key is a long string of characters that acts like a
# password — it lets the program use the AI on your behalf.
#
# Where to get each key:
#   OpenAI    →  https://platform.openai.com/api-keys
#   xAI       →  https://console.x.ai/
#   Gemini    →  https://aistudio.google.com/app/apikey
#   Anthropic →  https://console.anthropic.com/settings/keys
#
# You only need keys for the providers you plan to use.
# Paste your key after the = sign, with no spaces or quotes.
# Example:  OPENAI_API_KEY=sk-abc123xyz...
#

OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 2 — WHERE TO STORE YOUR STORIES
# ──────────────────────────────────────────────────────────────────────────────
#
# QUILLAN_DATA_DIR controls the folder where all story files are saved.
#
# The default (./quillan_data) puts everything in a folder called "quillan_data"
# inside whichever directory you run the program from. You can change this to
# any folder on your computer.
#
# Examples:
#   QUILLAN_DATA_DIR=./quillan_data          ← default: next to where you run it
#   QUILLAN_DATA_DIR=/Users/jane/my_stories  ← a fixed folder on your Mac
#   QUILLAN_DATA_DIR=C:\Users\jane\stories   ← a fixed folder on Windows
#

QUILLAN_DATA_DIR=./quillan_data


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 3 — SPEED AND COST
# ──────────────────────────────────────────────────────────────────────────────
#
# These settings control how quickly Quillan works and how much it costs.
# Using the AI services costs a small amount of money per scene drafted.
#
#
# QUILLAN_MAX_PARALLEL — how many scenes to draft at the same time
#
#   Higher = faster, but uses more money and may hit service limits.
#   Lower  = slower, cheaper, and less likely to encounter errors.
#
#   Allowed values: 1 (one at a time) up to about 10
#   Recommended for most writers: 3
#

QUILLAN_MAX_PARALLEL=3


# QUILLAN_MAX_PROMPT_TOKENS — how much context the AI can "see" at once
#
#   Each AI call can only hold a certain amount of text. This sets the limit.
#   Lowering it reduces cost slightly; raising it helps with very long scenes
#   or stories with a lot of accumulated history.
#
#   Allowed values: 4096 (small/cheap) to 128000 (very large, more expensive)
#   Recommended: 32768 (a good middle ground)
#

QUILLAN_MAX_PROMPT_TOKENS=32768


# QUILLAN_LLM_CACHE — save AI responses to avoid paying for repeated work
#
#   When set to true, Quillan saves the AI's responses to disk. If you run
#   the same prompt again (e.g. after a crash), it returns the saved response
#   instead of calling the AI again — saving time and money.
#
#   Set to false only if you always want a fresh response.
#
#   Allowed values: true, false
#

QUILLAN_LLM_CACHE=true


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 4 — STORY ORGANISATION (optional)
# ──────────────────────────────────────────────────────────────────────────────
#
# Stories are grouped into: world → canon → series
#
#   World  — a shared universe (e.g. "my_fantasy_world")
#   Canon  — a timeline within that world (e.g. "main_timeline")
#   Series — a story arc or book series (e.g. "the_dragon_trilogy")
#
# For a single standalone story you can leave these as "default" and not
# think about them at all. They become useful when you are writing multiple
# stories set in the same world, or a series of books that share characters.
#
# You can also override these per-command with --world, --canon, --series.
#

QUILLAN_CANON=default
QUILLAN_SERIES=default


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 5 — CONTINUITY AND MEMORY
# ──────────────────────────────────────────────────────────────────────────────
#
# As Quillan drafts scenes, it keeps a running record of what has happened:
# who is where, what events have occurred, which plot threads are still open.
# The settings below control how much of that history the AI can see at once.
#
#
# QUILLAN_CONTINUITY_LAST_BEATS_N — number of recent scenes to include in full
#
#   The AI always sees a summary of everything so far, plus the full text of
#   the most recent N scenes. More scenes = more context = better consistency,
#   but also more expensive.
#
#   Allowed values: 1–20   Recommended: 5
#

QUILLAN_CONTINUITY_LAST_BEATS_N=5


# QUILLAN_DISTILL_CONTINUITY — use AI to compress the continuity summary
#
#   For very long stories, the continuity summary can grow large. Setting this
#   to true tells Quillan to periodically ask the AI to condense it. This
#   costs a small number of extra AI calls but keeps the summary manageable.
#
#   Allowed values: true, false
#   Recommended: false (for short stories), true (for novels)
#

QUILLAN_DISTILL_CONTINUITY=false


# ──────────────────────────────────────────────────────────────────────────────
# SECTION 6 — ADVANCED / RARELY CHANGED
# ──────────────────────────────────────────────────────────────────────────────
#
# You almost certainly do not need to change anything below this line.
# These settings are for users who want to swap AI providers or fine-tune
# the behaviour of the drafting pipeline.
#
#
# AI PROVIDERS AND MODELS
#
# Quillan uses three providers for different tasks:
#   Planning  — builds the outline and beat specs         (default: OpenAI)
#   Draft     — writes the actual prose                   (default: xAI/Grok)
#   Forensic  — checks each draft for quality issues      (default: Gemini)
#
# Each task has four model "tiers". Quillan starts at tier0 (cheapest) and
# escalates automatically when the output fails quality checks:
#
#   Tier 0 — budget model on the primary provider (cheap first choice)
#   Tier 1 — quality model on the same provider   (escalate on quality failure)
#   Tier 2 — best model on a second provider      (escape if primary is down)
#   Tier 3 — best model on a third provider       (last-resort fallback)
#
# This means cost is optimised first, quality within the primary provider
# second, and cross-provider fallbacks only when the primary is unavailable.
#
# Each tier is configured as a (provider, model) pair. Supported providers:
#   openai, xai, gemini
#
# Planning defaults (OpenAI → OpenAI → xAI → Gemini):
# QUILLAN_PLANNING_TIER0_PROVIDER=openai
# QUILLAN_PLANNING_TIER0_MODEL=gpt-4o-mini
# QUILLAN_PLANNING_TIER1_PROVIDER=openai
# QUILLAN_PLANNING_TIER1_MODEL=gpt-4o
# QUILLAN_PLANNING_TIER2_PROVIDER=xai
# QUILLAN_PLANNING_TIER2_MODEL=grok-2
# QUILLAN_PLANNING_TIER3_PROVIDER=gemini
# QUILLAN_PLANNING_TIER3_MODEL=gemini-1.5-pro
#
# Draft defaults (xAI → xAI → OpenAI → Gemini):
# QUILLAN_DRAFT_TIER0_PROVIDER=xai
# QUILLAN_DRAFT_TIER0_MODEL=grok-2-mini
# QUILLAN_DRAFT_TIER1_PROVIDER=xai
# QUILLAN_DRAFT_TIER1_MODEL=grok-2
# QUILLAN_DRAFT_TIER2_PROVIDER=openai
# QUILLAN_DRAFT_TIER2_MODEL=gpt-4o
# QUILLAN_DRAFT_TIER3_PROVIDER=gemini
# QUILLAN_DRAFT_TIER3_MODEL=gemini-1.5-pro
#
# Forensic defaults (Gemini → Gemini → OpenAI → xAI):
# QUILLAN_FORENSIC_TIER0_PROVIDER=gemini
# QUILLAN_FORENSIC_TIER0_MODEL=gemini-1.5-flash
# QUILLAN_FORENSIC_TIER1_PROVIDER=gemini
# QUILLAN_FORENSIC_TIER1_MODEL=gemini-1.5-pro
# QUILLAN_FORENSIC_TIER2_PROVIDER=openai
# QUILLAN_FORENSIC_TIER2_MODEL=gpt-4o
# QUILLAN_FORENSIC_TIER3_PROVIDER=xai
# QUILLAN_FORENSIC_TIER3_MODEL=grok-2
#
#
# ERROR HANDLING
#
# QUILLAN_STAGE_MAX_RETRIES — how many times to retry a failed AI call
#   Allowed values: 0–5   Default: 1
#
# QUILLAN_STAGE_MAX_ESCALATIONS — how many tier escalations to allow per call
#   Allowed values: 0–3   Default: 3
#
# QUILLAN_RUN_MAX_CALLS — hard cap on total AI calls per run (0 = no cap)
#   Useful for testing: set to 10 to limit spending while exploring.
#
# QUILLAN_STAGE_MAX_RETRIES=1
# QUILLAN_STAGE_MAX_ESCALATIONS=3
# QUILLAN_RUN_MAX_CALLS=0
#
#
# TELEMETRY
#
# QUILLAN_TELEMETRY — save a summary of each run (token counts, timing, etc.)
#   These summaries are stored locally in quillan_data/.runs/ — they are never
#   sent anywhere. Set to false to disable.
#   Allowed values: true, false   Default: true
#
# QUILLAN_TELEMETRY=true
